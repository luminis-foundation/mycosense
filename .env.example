# MycoSense Environment Config
# Copy to .env and fill in values for live hardware mode.
# Without VITE_SENSOR_WS_URL, the dashboard runs in mock mode automatically.
# Never commit a populated .env file.

# WebSocket URL for your sensor server / serial bridge
# Example: ws://192.168.1.50:8765
VITE_SENSOR_WS_URL=

# Raspberry Pi local server URL (defaults to mDNS hostname if unset)
# Example: http://192.168.4.1:8765
VITE_PI_URL=

# Bearer token for Pi server authentication.
# Must match MYCOSENSE_API_TOKEN set on the Pi.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
VITE_PI_TOKEN=
